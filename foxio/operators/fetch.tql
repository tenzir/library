// Defunct: the formerly public `https://ja4db.com/api/read/` endpoint no
// longer appears to be available, and the current JA4DB API requires
// authentication. Keep this operator only for compatibility with existing
// pipelines.
from_http "https://ja4db.com/api/read/" {
  read_json arrays_of_objects=true
}
