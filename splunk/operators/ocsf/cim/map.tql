---
description: Splunk CIM → OCSF
---

// CIM data-model membership is tag/constraint based; CIM has no class UID.
_cim_tags = tag? else []
match _cim_tags {
  _ if "network" in _cim_tags and "resolution" in _cim_tags and "dns" in _cim_tags => {
    drop _cim_tags
    splunk::ocsf::cim::dns_activity
  }
  _ => {
    drop _cim_tags
  }
}
