---
description: Map OCSF network protocol metadata to Splunk CIM transport fields
---

cim.transport = connection_info?.protocol_name?
if cim.transport == null {
  match connection_info?.protocol_num? {
    1 => {
      cim.transport = "icmp"
    }
    6 => {
      cim.transport = "tcp"
    }
    17 => {
      cim.transport = "udp"
    }
    _ => {}
  }
}
