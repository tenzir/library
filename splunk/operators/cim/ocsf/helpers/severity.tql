---
description: OCSF severity → Splunk CIM severity fields
---

cim.severity = severity?.to_lower()
match severity_id? {
  0 => {
    cim.severity = "unknown"
  }
  1 => {
    cim.severity = "informational"
  }
  2 => {
    cim.severity = "low"
  }
  3 => {
    cim.severity = "medium"
  }
  4 => {
    cim.severity = "high"
  }
  5 => {
    cim.severity = "critical"
  }
  6 => {
    cim.severity = "critical"
  }
  _ => {}
}
cim.severity_id = severity_id?.string()
