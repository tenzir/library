---
name: Onboard Logs from NXlog xm_json
description: |
  Onboards and parses NXLog JSON logs from the provided URL and
  publishes them to the topic `nxlog`.
---

let $tls = {certfile: "/path/to/server-cert.pem", keyfile: "/path/to/server-key.pem"} if true else null

accept_tcp "tcp://0.0.0.0:1514", tls=$tls {
  nxlog::read
}
publish "nxlog"
