---
name: Check Point structured-data syslog → OCSF
description: Parse configured Check Point structured-data syslog and map it to OCSF.
---

accept_udp "udp://0.0.0.0:5514"
this = {...data.parse_syslog(), raw: data}
checkpoint::syslog::parse_structured_data
checkpoint::ocsf::map
ocsf::derive
ocsf::cast
