---
name: Parse Check Point firewall logs as OCSF
description: Parse a Check Point firewall record and map it to OCSF Network Activity.
---

from {
  action: "Accept",
  dst: 10.0.0.2,
  loguid: "{0x1,0x2,0x3,0x4}",
  origin: 10.0.0.254,
  product: "VPN-1 & FireWall-1",
  proto: 6,
  service: 443,
  service_id: "https",
  src: 10.0.0.1,
  s_port: 12345,
  time: 1771402491,
}
checkpoint::parse
checkpoint::ocsf::map
ocsf::derive
ocsf::cast
