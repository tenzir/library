---
name: Check Point pipe-KV syslog → OCSF
description: Parse configured Check Point pipe-delimited syslog messages and map them to OCSF.
---

accept_udp "udp://0.0.0.0:5514"
this = {...data.parse_syslog(), raw: data}
checkpoint::syslog::parse_kv_message
checkpoint::ocsf::map
ocsf::derive
ocsf::cast
