from_file f"{env("TENZIR_INPUTS")}/checkpoint-expanded.ndjson" {
  read_ndjson
}
checkpoint::parse
where loguid == "dlp-1"
checkpoint::ocsf::map
ocsf::derive
ocsf::cast
select action,
       action_id,
       actor,
       class_uid,
       data_security,
       disposition_id,
       dst_endpoint,
       file,
       finding_info,
       severity_id,
       src_endpoint,
       status_detail,
       status_id,
       unmapped
