from_file f"{env("TENZIR_INPUTS")}/checkpoint-expanded.ndjson" {
  read_ndjson
}
checkpoint::parse
where loguid == "vpn-1"
checkpoint::ocsf::map
ocsf::derive
ocsf::cast
select activity_id,
       class_uid,
       dst_endpoint,
       protocol_name,
       session,
       src_endpoint,
       status_id,
       traffic,
       tunnel_type_id,
       unmapped,
       user
