from_file f"{env("TENZIR_INPUTS")}/checkpoint-expanded.ndjson" {
  read_ndjson
}
checkpoint::parse
where loguid == "net-nat-1"
checkpoint::ocsf::map
ocsf::derive
ocsf::cast
select action,
       action_id,
       app_name,
       actor,
       connection_info,
       dst_endpoint,
       firewall_rule,
       src_endpoint,
       traffic,
       unmapped
