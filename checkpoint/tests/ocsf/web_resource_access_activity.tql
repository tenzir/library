from_file f"{env("TENZIR_INPUTS")}/checkpoint-expanded.ndjson" {
  read_ndjson
}
checkpoint::parse
where loguid == "url-1"
checkpoint::ocsf::map
ocsf::derive
ocsf::cast
select action,
       action_id,
       activity_id,
       actor,
       class_uid,
       disposition_id,
       http_request,
       src_endpoint,
       status_detail,
       status_id,
       unmapped,
       web_resources
