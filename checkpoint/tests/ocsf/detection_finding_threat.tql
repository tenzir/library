from_file f"{env("TENZIR_INPUTS")}/checkpoint-expanded.ndjson" {
  read_ndjson
}
checkpoint::parse
where loguid == "threat-1"
checkpoint::ocsf::map
ocsf::derive
ocsf::cast
select action,
       action_id,
       class_uid,
       confidence_id,
       disposition_id,
       evidences,
       finding_info,
       severity_id,
       unmapped
