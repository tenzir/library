from_file f"{env("TENZIR_INPUTS")}/checkpoint-expanded.ndjson" {
  read_ndjson
}
checkpoint::parse
where loguid == "email-1"
checkpoint::ocsf::map
ocsf::derive
ocsf::cast
select action,
       action_id,
       class_uid,
       direction_id,
       disposition_id,
       dst_endpoint,
       email,
       protocol_name,
       src_endpoint,
       status_detail,
       status_id,
       unmapped
