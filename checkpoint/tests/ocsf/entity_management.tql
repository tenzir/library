from_file f"{env("TENZIR_INPUTS")}/checkpoint-expanded.ndjson" {
  read_ndjson
}
checkpoint::parse
where loguid == "audit-1"
checkpoint::ocsf::map
ocsf::derive
ocsf::cast
select activity_id,
       actor,
       class_uid,
       comment,
       entity,
       src_endpoint,
       status_id,
       unmapped
