---
description: Extract Check Point fields from a read_syslog message field
---

this = {
  ...message.parse_kv(field_split="\\|", value_split="="),
  syslog: {
    facility: move facility?,
    severity: move severity?,
    version: move version?,
    timestamp: move timestamp?,
    hostname: move hostname?,
    app_name: move app_name?,
    process_id: move process_id?,
    message_id: move message_id?,
  },
}

checkpoint::parse
