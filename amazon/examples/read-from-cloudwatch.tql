---
name: Read events from CloudWatch Logs
description: Searches historical events in an existing CloudWatch log group.
---

let $log_group = "/tenzir/events"
let $log_stream = "default"
let $region = "us-east-1"

from_amazon_cloudwatch $log_group,
  mode="search",
  stream=$log_stream,
  start=now() - 1h,
  end=now(),
  aws_region=$region
