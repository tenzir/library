---
name: Send events to CloudWatch Logs
description: Sends sample log events to an existing CloudWatch log group and stream.
---

let $log_group = "/tenzir/events"
let $log_stream = "default"
let $region = "us-east-1"

from {
  timestamp: now(),
  message: f"tenzir-cloudwatch-test {now()}",
}
to_amazon_cloudwatch $log_group,
  stream=$log_stream,
  payload=message,
  timestamp=timestamp,
  aws_region=$region
