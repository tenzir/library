// Source: https://docs.paloaltonetworks.com/ngfw/administration/monitoring/use-syslog-for-monitoring/syslog-field-descriptions/audit-log-fields
let $audit_fields = [
  "serial_number",
  "generate_time",
  "threat_content_type",
  "future_use",
  "event_id",
  "object",
  "cli_command",
  "severity",
].join(",")

_panos = {
  audit_type: $field.split(",", max=5)[2]?,
  type: $field.split(",", max=5)[3]?,
  subtype: $field.split(",", max=5)[4]?,
}

match _panos.type {
  "TRAFFIC" => {
    this = $field.parse_csv(header=$traffic_fields).drop_matching("^future_use")
    @name = "paloalto.traffic"
  }
  "GLOBALPROTECT" => {
    this = $field.parse_csv(header=$globalprotect_fields).drop_matching("^future_use")
    @name = "paloalto.globalprotect"
  }
  "URL-FILTERING" => {
    this = $field.parse_csv(header=$url_filtering_fields).drop_matching("^future_use")
    @name = "paloalto.url-filtering"
  }
  "DATA-FILTERING" => {
    this = $field.parse_csv(header=$data_filtering_fields).drop_matching("^future_use")
    @name = "paloalto.data-filtering"
  }
  "THREAT" => {
    match _panos.subtype {
      "url" => {
        this = $field.parse_csv(header=$url_filtering_fields).drop_matching("^future_use")
        @name = "paloalto.url-filtering"
      }
      "data" | "dlp" | "dlp-non-file" => {
        this = $field.parse_csv(header=$data_filtering_fields).drop_matching("^future_use")
        @name = "paloalto.data-filtering"
      }
      _ => {
        this = $field.parse_csv(header=$threat_fields).drop_matching("^future_use")
        @name = "paloalto.threat"
      }
    }
  }
  "HIP-MATCH" => {
    this = $field.parse_csv(header=$hip_match_fields).drop_matching("^future_use")
    @name = "paloalto.hip-match"
  }
  "IPTAG" | "IP-TAGS" => {
    this = $field.parse_csv(header=$ip_tag_fields).drop_matching("^future_use")
    @name = "paloalto.ip-tags"
  }
  "USERID" | "USER-ID" => {
    this = $field.parse_csv(header=$user_id_fields).drop_matching("^future_use")
    @name = "paloalto.user-id"
  }
  "DECRYPTION" => {
    this = $field.parse_csv(header=$decryption_fields).drop_matching("^future_use")
    @name = "paloalto.decryption"
  }
  "TUNNEL" | "TUNNEL-INSPECTION" => {
    this = $field.parse_csv(header=$tunnel_inspection_fields).drop_matching("^future_use")
    @name = "paloalto.tunnel-inspection"
  }
  "SCTP" => {
    this = $field.parse_csv(header=$sctp_fields).drop_matching("^future_use")
    @name = "paloalto.sctp"
  }
  "CONFIG" => {
    this = $field.parse_csv(header=$config_fields).drop_matching("^future_use")
    @name = "paloalto.config"
  }
  "AUTHENTICATION" => {
    this = $field.parse_csv(header=$authentication_fields).drop_matching("^future_use")
    @name = "paloalto.authentication"
  }
  "SYSTEM" => {
    this = $field.parse_csv(header=$system_fields).drop_matching("^future_use")
    @name = "paloalto.system"
  }
  "CORRELATION" => {
    this = $field.parse_csv(header=$correlated_events_fields).drop_matching("^future_use")
    @name = "paloalto.correlation"
  }
  "GTP" => {
    this = $field.parse_csv(header=$gtp_fields).drop_matching("^future_use")
    @name = "paloalto.gtp"
  }
  "AUDIT" => {
    this = $field.parse_csv(header=$audit_fields).drop_matching("^future_use")
    @name = "paloalto.audit"
  }
  _ if _panos.audit_type == "AUDIT" => {
    this = $field.parse_csv(header=$audit_fields).drop_matching("^future_use")
    @name = "paloalto.audit"
  }
  _ => {
    @name = "paloalto.unknown"
  }
}

drop _panos?
