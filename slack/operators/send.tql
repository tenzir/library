---
description: Send events to a Slack incoming webhook
args:
  positional:
    - name: webhook_url
      description: The Slack incoming webhook URL.
      type: secret
  named:
    - name: parallel
      description: The maximum number of concurrent webhook requests.
      type: int
      default: 4
---

each parallel=$parallel {
  from $this
  slack::format
  to_http $webhook_url {
    write_json
  }
}
