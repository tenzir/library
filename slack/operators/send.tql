---
description: Send events to a Slack incoming webhook.
args:
  positional:
    - name: webhook_url
      description: The Slack incoming webhook URL.
      type: secret
  named:
    - name: message
      description: The Slack message text. Omit to serialize the current event.
      type: string
      default: null
    - name: thread_ts
      description: Optional Slack thread timestamp to reply to.
      type: string
      default: null
---

each {
  from $this
  _slack_text = $message else this.print_ndjson(strip_null_fields=true)
  select text=_slack_text, thread_ts=$thread_ts
  to_http $webhook_url, buffer_all=true {
    write_json strip_null_fields=true
  }
}
