// Pick one DB for deterministic results.
let $mmdb = "https://cra.circl.lu/opendata/geo-open/mmdb-country-asn/2025-12-03-GeoOpen-Country-ASN.mmdb"

from_http $mmdb {
  // FIXME: Replace the temporary `read_all` sink below with this once
  // `from_http` accepts parser subpipelines that consume bytes without
  // returning events:
  //
  // context::load "geo-open"
  read_all binary=true
}
where false
