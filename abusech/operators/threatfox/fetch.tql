---
description: Fetches recent ThreatFox indicators.
args:
  named:
    - name: auth_key
      type: secret
      description: ThreatFox API authentication key.
    - name: days
      type: int
      default: 3
      description: Number of days to request.
---

let $url = "https://threatfox-api.abuse.ch/api/v1/"
let $body = {query: "get_iocs", days: $days}
let $headers = {"Auth-Key": $auth_key}

from_http $url, body=$body, headers=$headers
abusech::threatfox::normalize
