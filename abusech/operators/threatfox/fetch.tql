---
description: Fetches recent ThreatFox indicators.
args:
  named:
    - name: auth_key
      type: secret
      description: ThreatFox API authentication key.
    - name: days
      type: int
      default: 3
      description: Number of days to request.
---

from_http "https://threatfox-api.abuse.ch/api/v1/",
  body={query: "get_iocs", days: $days},
  headers={"Auth-Key": $auth_key} {
  read_json
}
abusech::threatfox::normalize
