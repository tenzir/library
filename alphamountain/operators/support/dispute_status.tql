---
description: Fetches dispute status by ticket ID.
args:
  named:
    - name: license
      type: secret
      description: alphaMountain API license key.
    - name: ticket_id
      type: int
      description: Dispute ticket ID.
---

let $body = {
  license: $license,
  ticket_id: $ticket_id,
}

alphamountain::api::post_json_array url="https://api.alphamountain.ai/support/dispute/status", body=$body
@name = "alphamountain.support.dispute_status"
