---
description: Fetches the CSV host popularity feed.
args:
  named:
    - name: license
      type: secret
      description: alphaMountain API license key.
    - name: limit
      type: int
      default: null
      description: Optional record limit.
---

let $body = {
  license: $license,
  version: 1,
  limit: $limit,
}

alphamountain::api::post_csv url="https://batch.alphamountain.ai/popularity/feed/csv", body=$body
@name = "alphamountain.popularity"
