from_file f"{env("TENZIR_INPUTS")}/threat-uris-errors.json" {
  read_json arrays_of_objects=true, raw=true
}
_score_uris = (scores? else {}).keys()
uri = [
  ..._score_uris,
  ...(errors? else {}).keys().where(x => not (x in _score_uris)),
]
unroll uri
_error = (errors? else {}).get(uri, null)
this = {
  ...(scores? else {}).get(uri, {}),
  ...({error: move _error} if _error? != null else {}),
  uri: move uri,
  status: move status,
  version: move version,
}
sort uri
