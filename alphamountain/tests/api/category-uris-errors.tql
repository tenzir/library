from_file f"{env("TENZIR_INPUTS")}/category-uris-errors.json" {
  read_json arrays_of_objects=true, raw=true
}
_category_uris = (categories? else {}).keys()
uri = [
  ..._category_uris,
  ...(errors? else {}).keys().where(x => not (x in _category_uris)),
]
unroll uri
_error = (errors? else {}).get(uri, null)
this = {
  ...(categories? else {}).get(uri, {}),
  ...({error: move _error} if _error? != null else {}),
  uri: move uri,
  status: move status,
  version: move version,
}
sort uri
