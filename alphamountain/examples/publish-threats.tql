---
name: Publish alphaMountain Threats Feed
description: |
  An example that periodically fetches the alphaMountain Threats Feed and
  publishes it to the `alphamountain` topic.
---

let $url = "https://batch.alphamountain.ai/threat/feed/csv"
let $body = {
  version: 1,
  license: "ALPHAMOUNTAIN_LICENSE",
  risk_min: 8.5,
  risk_max: 10.0,
}
every 1h {
  from_http $url, body=$body {
    read_csv
  }
}
@name = "alphamountain.threat"
publish "alphamountain"
