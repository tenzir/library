---
name: Publish alphaMountain Threats as OCSF
description: |
  Periodically fetches high-scoring alphaMountain threats, maps them to OCSF
  OSINT Inventory Info, and publishes them to the `ocsf` topic.
---

every 1h {
  alphamountain::threat::feed license="ALPHAMOUNTAIN_LICENSE",
    risk_min=8.5,
    risk_max=10.0
  alphamountain::ocsf::map
  ocsf::derive
  ocsf::cast
}
publish "ocsf"
