---
name: Publish alphaMountain Categories Feed
description: |
  An example that periodically fetches the alphaMountain Categories Feed
  and publishes it to the `alphamountain` topic.
---

let $url = "https://batch.alphamountain.ai/category/feed/csv"
let $body = {
  version: 1,
  license: "ALPHAMOUNTAIN_LICENSE",
}
every 1h {
  from_http $url, body=$body {
    read_csv
  }
}
@name = "alphamountain.category"
publish "alphamountain"
