---
name: Publish alphaMountain Categories as OCSF
description: |
  Periodically fetches the alphaMountain Categories Feed, maps it to OCSF
  OSINT Inventory Info, and publishes it to the `ocsf` topic.
---

every 1h {
  alphamountain::category::feed license="ALPHAMOUNTAIN_LICENSE"
  alphamountain::ocsf::map
  ocsf::derive
  ocsf::cast
}
publish "ocsf"
