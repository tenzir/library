  category_uid: 4,
  class_uid: 4003,
  severity_id: 1,
  time: 2024-01-01T00:00:00Z,
  type_uid: 400301,
  metadata: {
    product: {
      name: "Test",
      vendor_name: "Tenzir",
    },
    version: "1.8.0",
  },
  query: {
    hostname: "example.com",
  },
  unmapped: {
    vendor_field: "kept",
  },
}
@name = "ocsf.dns_activity"
tenzir::trim size="L"
select activity_name, class_name, metadata, query, unmapped
