---
description: Trims OCSF events according to a size profile.
args:
  named:
    - name: size
      type: string
      default: M
      description: |
        Size profile: S, M, or L.
---

match $size {
  "S" => {
    ocsf::trim drop_optional=true, drop_recommended=true
  }
  "L" => {
    ocsf::trim drop_optional=false, drop_recommended=false
    ocsf::derive
  }
  _ => {
    ocsf::trim drop_optional=true, drop_recommended=false
  }
}
