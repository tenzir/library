---
name: "Okta System Log: HTTP Receiver"
description: |
  Polls the Okta System Log API for new events.
disabled: true
---

every 30s {
  load_http "https://{{ inputs.api-domain }}/api/v1/logs?sortOrder=ASCENDING&limit=100", headers={
    Authorization: "SSWS {{ inputs.api-token }}",
  }
  read_json
}
publish "okta"
