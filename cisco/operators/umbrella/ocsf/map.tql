---
description: Cisco Umbrella → OCSF
---

this = {umbrella: this}
ocsf = {}

ocsf.metadata = {
  product: {
    name: "Umbrella",
    vendor_name: "Cisco",
  },
  profiles: ["host", "security_control"],
  version: "1.8.0",
}
ocsf.severity_id = 1

match @name {
  "cisco.umbrella.dns" => {
    cisco::umbrella::ocsf::events::dns
  }
  _ => {
    cisco::umbrella::ocsf::base
  }
}

this = {...ocsf, unmapped: umbrella}
