---
name: Cisco Umbrella DNS S3 export → OCSF
description: |
  Reads Cisco Umbrella DNS CSV exports from S3 and maps them to OCSF DNS
  Activity.
---

let $url = "s3://example-umbrella-bucket/org-id/**/*.csv.gz"
let $aws_iam = {region: "eu-central-1"}

cisco::umbrella::dns::from_s3 $url, watch=15m, aws_iam=$aws_iam
cisco::umbrella::ocsf::map
ocsf::derive
ocsf::cast
