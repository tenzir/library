// Segment 0 may carry a later syslog timestamp than its continuation, putting
// the header on the far side of a fixed window boundary.
from {
  message: "CISE_Failed_Attempts 0001133667 2 0 2026-06-18 13:44:56.100 +02:00 0020933896 5400 NOTICE Failed-Attempt: Authentication failed, UserName=alice, NetworkDeviceGroups=Location#All Locations#Site1,",
  timestamp: 2026-06-18T11:44:56.100Z,
},
{
  message: "CISE_Failed_Attempts 0001133667 2 1 AcsSessionID=ise-psn1/123456789/99, EndPointMACAddress=00-11-22-33-44-99, NetworkDeviceGroups=Location#All Locations#Site1, CPMSessionID=0a0000010000000000000002,",
  timestamp: 2026-06-18T11:44:55.900Z,
}
cisco::ise::reassemble message=message, on=timestamp, span=1s
select message_id, segment_total, reassembly_complete, missing_segments, message
