// An orphan ISE fragment: a continuation segment whose header segment 0 never
// arrived, so reassembly produced a body with no header (only attributes). The
// parser keeps it instead of dropping it, tags it `cisco.ise.incomplete`, and
// the mapper labels it as an OCSF Base Event (`metadata.labels`), with the
// attributes it does carry preserved in `unmapped`.
from {message: "0009000001 2 0 cisco-av-pair=dc-device-name=Unknown Device, cisco-av-pair=dc-device-class-tag=Un-Classified Device, AcsSessionID=ise-psn1/123456789/99, EndPointMACAddress=00-11-22-33-44-99, NetworkDeviceGroups=Location#All Locations#Site1, CPMSessionID=0a0000010000000000000002,"}
cisco::ise::parse
cisco::ise::ocsf::map
ocsf::derive
ocsf::cast
