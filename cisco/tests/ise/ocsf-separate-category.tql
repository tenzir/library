from {
  category: "CISE_Passed_Authentications",
  message: "0000001001 1 0 2024-01-15 12:00:00.100 +00:00 0000000001 5200 NOTICE Passed-Authentication: Authentication succeeded, UserName=example-user, SelectedAccessService=Default Network Access,",
  timestamp: 2026-01-15T12:00:00Z,
},
{
  category: "CISE_Failed_Attempts",
  message: "0000001002 2 0 2024-01-15 12:00:01.100 +00:00 0000000002 5400 NOTICE Failed-Attempt: Authentication failed, UserName=other-user, FailureReason=Subject not found,",
  timestamp: 2026-01-15T12:00:01Z,
},
{
  category: "CISE_Failed_Attempts",
  message: "0000001002 2 1 SelectedAccessService=Default Network Access,",
  timestamp: 2026-01-15T12:00:02Z,
},
{
  message: "0000001003 1 0 2024-01-15 12:00:03.100 +00:00 0000000003 5200 NOTICE Passed-Authentication: Authentication succeeded, UserName=unknown-family,",
  timestamp: 2026-01-15T12:00:03Z,
}
cisco::ise::reassemble message=message, on=timestamp, span=30s
cisco::ise::parse category=category
cisco::ise::ocsf::map
ocsf::derive
ocsf::cast
select metadata.original_event_uid, metadata.event_code, class_name, type_name, status?, service?, user?, unmapped
sort metadata.original_event_uid
