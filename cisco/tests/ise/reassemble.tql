// Reassemble a Cisco ISE message that ISE split across several BSD syslog
// messages (one segment per line, sharing a message id), then parse and map the
// complete message. BSD syslog timestamps carry no year, so we assign the
// current year—rolling over the year boundary so a December event seen in
// January, or a January event seen in December, lands in the right year—and
// window the segments on the resulting time. The segments are fed out of order
// (2, 0, 3, 1) on purpose: reassembly must sort them by segment number.
from {message: r"<181>Jun 18 13:44:55 ise-psn1 CISE_Failed_Attempts 0001133664 4 2  AuthorizationPolicyMatchedRule=Default, UserType=Host, CPMSessionID=0a0000010000000000000001, EndPointMACAddress=00-11-22-33-44-66, EndPointMatchedProfile=Unknown, DeviceRegistrationStatus=notRegistered, ISEPolicySetName=Wired MAB, StepLatency=1=0\;2=0\;3=1, TotalAuthenLatency=11, DTLSSupport=Unknown, Location=Location#All Locations#Site1,"},
     {message: r"<181>Jun 18 13:44:55 ise-psn1 CISE_Failed_Attempts 0001133664 4 0 2026-06-18 13:44:55.106 +02:00 0020933894 5400 NOTICE Failed-Attempt: Authentication failed, ConfigVersionId=39, Device IP Address=10.0.0.3, Device Port=61619, DestinationIPAddress=10.0.0.2, DestinationPort=1812, RadiusPacketType=AccessRequest, UserName=00-11-22-33-44-66, Protocol=Radius, NetworkDeviceName=switch-02, User-Name=001122334466, NAS-IP-Address=10.0.0.3, NAS-Port=50106, Service-Type=Call Check, Framed-MTU=1468, Called-Station-ID=AA-BB-CC-DD-EE-FF, Calling-Station-ID=00-11-22-33-44-66, NAS-Port-Type=Ethernet, NAS-Port-Id=GigabitEthernet1/0/6, cisco-av-pair=audit-session-id=0a0000010000000000000001, cisco-av-pair=method=mab, OriginalUserName=001122334466, NetworkDeviceProfileName=Cisco, IsThirdPartyDeviceFlow=false, RadiusFlowType=WiredMAB,"},
     {message: r"<181>Jun 18 13:44:55 ise-psn1 CISE_Failed_Attempts 0001133664 4 3  Mode=Mode#Mode, Name=Endpoint Identity Groups:Unknown, Response={RadiusPacketType=AccessReject; AuthenticationResult=Passed; UserName=00:11:22:33:44:66; },"},
     {message: r"<181>Jun 18 13:44:55 ise-psn1 CISE_Failed_Attempts 0001133664 4 1  SSID=AA-BB-CC-DD-EE-FF, AcsSessionID=ise-psn1/123456789/47, AuthenticationIdentityStore=Internal Endpoints, AuthenticationMethod=Lookup, SelectedAccessService=MAB, SelectedAuthorizationProfiles=DenyAccess, UseCase=Host Lookup, RequestLatency=11, IdentityGroup=Endpoint Identity Groups:Unknown, FailureReason=15039 Rejected per authorization profile, Step=11001, Step=15039, Step=11003, NetworkDeviceGroups=Location#All Locations#Site1, IdentityPolicyMatchedRule=Default,"}
this = message.parse_syslog()
event_month = timestamp.parse_time("%b %e %H:%M:%S").month()
year = now().year()
if event_month == 12 and now().month() == 1 {
  year = year - 1
} else if event_month == 1 and now().month() == 12 {
  year = year + 1
}
timestamp = (year.string() + " " + timestamp).parse_time("%Y %b %e %H:%M:%S")
drop event_month, year
cisco::ise::reassemble message=content, on=timestamp
cisco::ise::parse
cisco::ise::ocsf::map
ocsf::derive
ocsf::cast
