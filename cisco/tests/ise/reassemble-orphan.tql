// Segment 1 arrives without segment 0. Reassembly emits the orphan fragment so
// the parser can keep its attributes as an incomplete OCSF Base Event.
from {
  message: "CISE_Failed_Attempts 0001133666 2 1 AcsSessionID=ise-psn1/123456789/99, EndPointMACAddress=00-11-22-33-44-99, NetworkDeviceGroups=Location#All Locations#Site1, CPMSessionID=0a0000010000000000000002,",
  timestamp: 2026-06-18T11:44:56.106Z,
}
cisco::ise::reassemble message=message, on=timestamp, window=1s
cisco::ise::parse
cisco::ise::ocsf::map
ocsf::derive
ocsf::cast
