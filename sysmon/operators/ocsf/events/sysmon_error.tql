---
description: >
  Sysmon Error (EID 255) → OCSF Base Event (0).
  Internal Sysmon errors have no OCSF class; the error ID and description
  are preserved in unmapped for triage.
---

// Base Event — internal Sysmon errors do not map to any OCSF class.
ocsf.category_uid = 0
ocsf.class_uid = 0
ocsf.activity_id = 0
ocsf.type_uid = 0
