---
name: Onboard Sophos SIEM Integration API (Alerts)
description: |
  Periodically fetches alerts from the Sophos SIEM Integration API.
disabled: true
---

every {{ inputs.poll-frequency }}s {
  sophos::siem::fetch \
    client_id="{{ inputs.client-id }}",
    client_secret=secret("{{ inputs.client-secret }}"),
    endpoint="alerts"
}
deduplicate id, create_timeout=25h
publish "sophos"
