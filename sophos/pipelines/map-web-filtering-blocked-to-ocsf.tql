---
name: Sophos Web Filtering Blocked to OCSF Remediation Activity
description: Maps Sophos web filtering blocked events to OCSF Remediation Activity.
---

subscribe "sophos"
where @name == "sophos.event"
where type == "Event::Endpoint::WebFilteringBlocked"
sophos::ocsf::events::remediation_activity
publish "ocsf"
