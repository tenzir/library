---
name: Sophos PUA Cleanup to OCSF File Remediation Activity
description: Maps Sophos CorePuaClean events to OCSF File Remediation Activity.
---

subscribe "sophos"
where @name == "sophos.event"
where type == "Event::Endpoint::CorePuaClean"
sophos::ocsf::events::file_remediation_activity
publish "ocsf"
