---
name: Onboard Sophos SIEM Integration API (Events)
description: |
  Periodically fetches events from the Sophos SIEM Integration API.
---

every 60s {
  sophos::siem::fetch \
    client_id="CLIENT_ID",
    client_secret=secret("CLIENT_SECRET"),
    endpoint="events"
}
deduplicate id, create_timeout=25h
publish "sophos"
