---
description: "FortiGate DNS filter logs → OCSF DNS Activity (4003)"
---

@name = "ocsf.dns_activity"

// FortiGate eventtype → OCSF activity_id.
let $activities = {
  "dns-response": 2,
}

ocsf.category_uid = 4
ocsf.class_uid = 4003
ocsf.activity_id = $activities[unmapped.eventtype?]? else 1
ocsf.type_uid = ocsf.class_uid * 100 + ocsf.activity_id

ocsf.query = {
  hostname: move unmapped.qname,
  class: move unmapped.qclass,
  type: move unmapped.qtype
}
