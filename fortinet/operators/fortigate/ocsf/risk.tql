---
description: >-
  FortiGate UTM composite risk fields → OCSF risk_score and
  risk_level_id. `crscore` is the numeric risk score; `crlevel` is its
  normalized label (low/medium/high/critical).
---

if ocsf.unmapped.crscore? != null {
  ocsf.risk_score = move ocsf.unmapped.crscore
}
if ocsf.unmapped.crlevel? != null {
  let $levels = {
    low: 1,
    medium: 2,
    high: 3,
    critical: 4,
  }
  ocsf.risk_level_id = $levels[move ocsf.unmapped.crlevel]? else 99
}
