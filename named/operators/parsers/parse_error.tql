---
description: Mark a BIND named parser branch as failed.
args:
  named:
    - name: event
      description: The record field to mark.
      type: field
---

@name = "named.parser_error"
$event.category = "parser"
$event.template = "parse_grok_failed"
$event.parser = {
  warning: "failed to parse named message",
  reason: "recognized message template did not match detailed grok parser",
}
