---
description: Maps Google SecOps UDM event and entity records to OCSF 1.8.0.
args:
  named:
    - name: event
      description: The field that holds the UDM record to map.
      type: field
      default: this
---

if $event.metadata.entityType? != null or $event.entity? != null {
  google::ocsf::udm::entity::map event=$event
} else {
  google::ocsf::udm::event::map event=$event
}
