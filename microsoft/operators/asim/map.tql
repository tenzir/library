---
description: Maps supported Microsoft events to Microsoft Sentinel ASIM.
args:
  named:
    - name: raw
      description: Raw Microsoft event to preserve in OCSF `raw_data` before ASIM mapping.
      default: null
---

if class_uid? != null {
  microsoft::asim::ocsf::map
} else {
  microsoft::ocsf::map raw=$raw
  ocsf::derive
  ocsf::cast
  microsoft::asim::ocsf::map
}
