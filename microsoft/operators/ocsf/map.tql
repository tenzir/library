---
description: Microsoft event -> OCSF.
args:
  positional:
    - name: log
      description: The field that holds a raw Microsoft event, such as Windows Event Log XML.
      default: null
---

if $log != null {
  _microsoft_ocsf_log = $log
  microsoft::windows::ocsf::map _microsoft_ocsf_log
} else {
  microsoft::graph::ocsf::map
}
