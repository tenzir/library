---
description: Maps supported Microsoft events to OCSF.
args:
  named:
    - name: raw
      description: Raw Microsoft event to preserve in OCSF `raw_data`.
      default: null
---

if @name == "microsoft.windows.eventlog" or System? != null {
  microsoft::windows::ocsf::map raw=$raw
} else {
  microsoft::graph::ocsf::map raw=$raw
}
