---
description: Logon with Explicit Credentials (EID 4648) → OCSF Authentication (3002, Logon)
---

@name = "ocsf.authentication"

ocsf.category_uid = 3
ocsf.class_uid = 3002
ocsf.activity_id = 1  // Logon
ocsf.type_uid = ocsf.class_uid * 100 + ocsf.activity_id

// EID 4648 records the attempt, not the outcome; no status is available.

ocsf.user = {
  name: move windows.EventData.TargetUserName,
  domain: move windows.EventData.TargetDomainName,
}

// The process that called LogonUser/CreateProcessWithLogonW.
ocsf.actor = {
  user: {
    uid: move windows.EventData.SubjectUserSid,
    name: move windows.EventData.SubjectUserName,
    domain: move windows.EventData.SubjectDomainName,
  },
  session: {
    uid: move windows.EventData.LogonGuid,
    uid_alt: move windows.EventData.SubjectLogonId,
  },
  process: {
    pid: int(move windows.EventData.ProcessId, base=16),
    path: move windows.EventData.ProcessName,
    file: { type_id: 8 },
  },
}
ocsf.actor.process.name = ocsf.actor.process.path.split("\\")[-1]
ocsf.actor.process.file.name = ocsf.actor.process.name
ocsf.actor.process.file.path = ocsf.actor.process.path

ocsf.dst_endpoint = {
  hostname: move windows.EventData.TargetServerName,
}

// Where the logon originated from (may differ from the actor's host in lateral movement).
ocsf.src_endpoint = {
  ip: move windows.EventData.IpAddress,
  port: move windows.EventData.IpPort,
}

// TargetLogonGuid and TargetInfo stay in unmapped; no clean OCSF mapping.
