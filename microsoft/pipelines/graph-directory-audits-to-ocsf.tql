---
name: Microsoft Graph Directory Audits → OCSF
disabled: true
---

every {{ inputs.graph-refresh-interval }} {
  microsoft::graph::directory_audits
    tenant_id="{{ inputs.tenant-id }}",
    client_id="{{ inputs.client-id }}",
    client_secret=secret("{{ inputs.client-secret }}"),
    lookback={{ inputs.graph-refresh-interval }}
}
microsoft::graph::ocsf::map
this = ocsf
ocsf::derive
ocsf::cast
publish "ocsf"
