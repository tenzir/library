---
name: Microsoft Graph Intune Compliance → OCSF
---

every 5m {
  microsoft::graph::intune::compliance_policy_setting_state_summaries \
    tenant_id="TENANT_ID",
    client_id="CLIENT_ID",
    client_secret=secret("CLIENT_SECRET")
}
microsoft::ocsf::map event=this
ocsf::derive
ocsf::cast
publish "ocsf"
