---
name: Microsoft Graph Risk Detections → OCSF
---

every 5m {
  microsoft::graph::identity_protection::risk_detections \
    tenant_id="TENANT_ID",
    client_id="CLIENT_ID",
    client_secret=secret("CLIENT_SECRET")
}
event = this
microsoft::ocsf::map event=event
this = event
ocsf::derive
ocsf::cast
publish "ocsf"
