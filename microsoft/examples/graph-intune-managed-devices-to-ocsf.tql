---
name: Collect Microsoft Intune managed devices as OCSF
description: Fetch Microsoft Intune managed devices from Microsoft Graph and map them to OCSF Device Inventory Info events.
---

microsoft::graph::intune::managed_devices
  tenant_id="{{ inputs.tenant-id }}",
  client_id="{{ inputs.client-id }}",
  client_secret=secret("{{ inputs.client-secret }}")
microsoft::graph::ocsf::map
ocsf::derive
ocsf::cast
