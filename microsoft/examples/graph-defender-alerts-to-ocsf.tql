---
name: Collect Microsoft Defender alerts as OCSF
description: Fetch Microsoft Defender alerts from Microsoft Graph and map them to OCSF Detection Finding events.
---

microsoft::graph::defender::alerts
  tenant_id="{{ inputs.tenant-id }}",
  client_id="{{ inputs.client-id }}",
  client_secret=secret("{{ inputs.client-secret }}"),
  lookback={{ inputs.graph-refresh-interval }}
microsoft::graph::ocsf::map
this = ocsf
ocsf::derive
ocsf::cast
