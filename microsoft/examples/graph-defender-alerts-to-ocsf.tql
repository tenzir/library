---
name: Microsoft Defender alerts → OCSF
description: Fetch Microsoft Defender alerts from Microsoft Graph and map them to OCSF Detection Finding events.
---

microsoft::graph::defender::alerts \
  tenant_id="TENANT_ID",
  client_id="CLIENT_ID",
  client_secret=secret("CLIENT_SECRET"),
  lookback=5m
event = this
microsoft::ocsf::map event=event
this = event
ocsf::derive
ocsf::cast
