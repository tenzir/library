---
name: Microsoft Graph Defender Incidents → OCSF
---

every 5m {
  microsoft::graph::defender::incidents \
    tenant_id="TENANT_ID",
    client_id="CLIENT_ID",
    client_secret=secret("CLIENT_SECRET"),
    lookback=5m
}
event = this
microsoft::ocsf::map event=event
this = event
ocsf::derive
ocsf::cast
publish "ocsf"
