---
name: Collect Microsoft Graph sign-ins as OCSF
description: Fetch recent Microsoft Entra ID sign-in logs and map them to OCSF Authentication events.
---

microsoft::graph::sign_ins
  tenant_id="{{ inputs.tenant-id }}",
  client_id="{{ inputs.client-id }}",
  client_secret=secret("{{ inputs.client-secret }}"),
  lookback={{ inputs.graph-refresh-interval }}
microsoft::graph::ocsf::map
this = ocsf
ocsf::derive
ocsf::cast
