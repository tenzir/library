from_file f"{env("TENZIR_INPUTS")}/eid-9999.xml" {
  read_all
}
payload = data.parse_winlog()
windows = "outer-windows"
ocsf = "outer-ocsf"
microsoft::windows::ocsf::map event=payload
select windows,
       ocsf,
       payload_class_uid=payload.class_uid,
       payload_event_code=payload.metadata.event_code
