from_file f"{env("TENZIR_INPUTS")}/graph/sign-ins.ndjson" {
  read_json
}
@name = "microsoft.graph.sign_in"
microsoft::asim::map
name = @name
sort EventOriginalUid
select name, EventSchema, EventSchemaVersion, EventType,
  EventResult, EventProduct, EventVendor, EventOriginalType,
  EventOriginalUid, Dvc, SrcIpAddr=SrcIpAddr?,
  TargetUsername, TargetUserId, TargetAppName=TargetAppName?
