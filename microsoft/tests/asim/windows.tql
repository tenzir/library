from_file f"{env("TENZIR_INPUTS")}/eid-4624.xml" {
  read_all
}
win = data.parse_winlog()
microsoft::windows::ocsf::map event=win
win.raw_data = move data
win.raw_data_size = win.raw_data.length_bytes()
this = win
ocsf::derive
ocsf::cast
microsoft::asim::map event=this
name = @name
drop AdditionalFields.metadata.processed_time?
