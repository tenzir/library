from_file f"{env("TENZIR_INPUTS")}/eid-4624.xml" {
  read_all
}
microsoft::asim::map data
name = @name
select name, EventSchema, EventSchemaVersion, EventType,
  EventResult, EventProduct, EventVendor, EventOriginalType,
  EventOriginalUid, Dvc, DvcHostname, SrcIpAddr=SrcIpAddr?,
  TargetUsername, TargetUsernameType, TargetUserId, TargetUserIdType,
  LogonProtocol=LogonProtocol?
