from {
  marker: "parsed",
  dhcpd: {
    time: 2026-01-01T00:00:00Z,
    message: "DHCPACK on 192.0.2.10 to aa:bb:cc:dd:ee:ff (host-1) via eth0",
    keep: "inner-parsed",
  },
}, {
  marker: "parser-error",
  dhcpd: {
    time: 2026-01-01T00:00:00Z,
    keep: "inner-error",
  },
}

dhcpd::parse event=dhcpd
dhcpd::ocsf::map event=dhcpd

dhcpd.unmapped.outer_marker = move marker
this = move dhcpd
ocsf::cast

drop_null_fields
sort time, unmapped.outer_marker
